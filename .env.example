# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Google Calendar (optional) ────────────────────────────────────────────────
GOOGLE_CALENDAR_ID=your_calendar_id@gmail.com
GOOGLE_CREDENTIALS_PATH=/mnt/storage/pi-assistant/config/google_credentials.json
GOOGLE_TOKEN_PATH=/mnt/storage/pi-assistant/config/google_token.json

# ── Email (optional) ──────────────────────────────────────────────────────────
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── VS Code Bridge (your PC's LAN IP) ─────────────────────────────────────────
VSCODE_BRIDGE_HOST=http://192.168.1.153:5055

# ── Chromecast (optional) ─────────────────────────────────────────────────────
CHROMECAST_TV_NAME=Living Room TV
CHROMECAST_SPEAKER_NAME=Living Room Speaker
